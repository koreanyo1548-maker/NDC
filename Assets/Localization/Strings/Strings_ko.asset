    m_Metadata:
      m_Items: []
  - m_Id: 366522447769600
    m_Localized: "\uD55C\uC815<br>\uD310\uB9E4"
    m_Metadata:
      m_Items: []
  - m_Id: 2554500389613568
    m_Localized: "\uC601\uC0C1 \uC7AC\uC0DD\uC5D0 \uC624\uB958\uAC00 \uBC1C\uC0DD\uD588\uC2B5\uB2C8\uB2E4.
      \uC601\uC0C1\uC744 \uC885\uB8CC\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2554500427362304
    m_Localized: "\uC571 \uB0B4 \uAD6C\uC785 \uAE30\uB2A5\uC774 \uCC28\uB2E8\uC774
      \uB418\uC5B4 \uAD6C\uB9E4\uAC00 \uBD88\uAC00\uD569\uB2C8\uB2E4. \uD574\uC81C
      \uD6C4 \uB2E4\uC2DC \uC2DC\uB3C4\uD574 \uC8FC\uC138\uC694. (\uC124\uC815 >
      \uC2A4\uD06C\uB9B0 \uD0C0\uC784 > \uCF58\uD150\uCE20 \uBC0F \uAC1C\uC778 \uC815\uBCF4
      \uBCF4\uD638 \uC81C\uD55C > iTunes \uBC0F App Store \uAD6C\uC785 > \uC571 \uB0B4
      \uAD6C\uC785)"
    m_Metadata:
      m_Items: []
  - m_Id: 2554500427362305
    m_Localized: "\uAD6C\uB9E4 \uCC98\uB9AC \uC911 \uBB38\uC81C\uAC00 \uBC1C\uC0DD\uD558\uC600\uC2B5\uB2C8\uB2E4.
      \uAD6C\uB9E4\uB97C \uC7AC\uC2DC\uB3C4\uD574\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 2554500427362306
    m_Localized: "\uAD6C\uB9E4 \uBCF5\uAD6C \uCC98\uB9AC \uC911 \uBB38\uC81C\uAC00
      \uBC1C\uC0DD\uD558\uC600\uC2B5\uB2C8\uB2E4. \uB2E4\uC74C\uAC8C\uC784 \uC7AC\uC2DC\uC791\uC2DC
      \uAD6C\uB9E4 \uBCF5\uAD6C\uAC00 \uC7AC\uCC98\uB9AC \uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
