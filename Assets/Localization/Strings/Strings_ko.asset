      m_Items: []
  - m_Id: 1027664064530
    m_Localized: "\uACC4\uC815\uC758 \uB2C9\uB124\uC784\uC744 \uC785\uB825\uD558\uACE0
      '\uACC4\uC815 \uC0AD\uC81C'\uBC84\uD2BC\uC744 \uB20C\uB7EC\uC8FC\uC138\uC694.
      <br>\uAD6C\uB9E4 \uB0B4\uC5ED, \uACC4\uC815 \uC5F0\uB3D9\uC744 \uD3EC\uD568\uD55C
      \uBAA8\uB4E0 \uB370\uC774\uD130\uAC00 \uC0AD\uC81C\uB418\uACE0 \uAC8C\uC784\uC744
      \uC885\uB8CC\uD569\uB2C8\uB2E4."
