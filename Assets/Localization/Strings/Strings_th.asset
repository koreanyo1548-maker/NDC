    m_Localized: "\u0E1E\u0E31\u0E01\u0E19\u0E35\u0E49\u0E40\u0E01\u0E34\u0E14\u0E27\u0E34\u0E0D\u0E0D\u0E32\u0E13\u0E04\u0E25\u0E31\u0E48\u0E07\u0E44\u0E21\u0E48\u0E2B\u0E22\u0E38\u0E14\u0E2B\u0E22\u0E48\u0E2D\u0E19\u0E40\u0E25\u0E22\u0E43\u0E19\u0E42\u0E25\u0E01\u0E2B\u0E25\u0E31\u0E07\u0E04\u0E27\u0E32\u0E21\u0E15\u0E32\u0E22"
