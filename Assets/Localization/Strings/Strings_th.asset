    m_Localized: "\u0E23\u0E32\u0E0A\u0E32\u0E01\u0E1A\u0E44\u0E14\u0E49\u0E23\u0E31\u0E1A\u0E01\u0E32\u0E23\u0E0A\u0E33\u0E23\u0E30\u0E25\u0E49\u0E32\u0E07\u0E41\u0E25\u0E49\u0E27
