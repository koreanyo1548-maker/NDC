      m_Items: []
  - m_Id: 1027647287317
    m_Localized: Keine Gegner in Reichweite.
    m_Metadata:
      m_Items: []
  - m_Id: 1027647287318
    m_Localized: Auf deiner aktuellen Stufe kannst du den Autom. Abschluss nicht
      benutzen.
    m_Metadata:
      m_Items: []
  - m_Id: 1027647287319
    m_Localized: Bitte gib einen korrekten Spitznamen ein.
