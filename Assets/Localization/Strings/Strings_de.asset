    m_Metadata:
      m_Items: []
  - m_Id: 5530286453239808
    m_Localized: "Kauf abschlie\xDFen"
    m_Metadata:
      m_Items: []
  - m_Id: 5530286503571456
    m_Localized: Eine Kaufanfrage wird verarbeitet.<br>Bitte warten.
    m_Metadata:
      m_Items: []
  - m_Id: 5829620440838144
    m_Localized: "Vor kurzem fand ein Login von einem anderen Ger\xE4t statt.<br>Wenn
      du aktuell von einem anderen Ger\xE4t angemeldet bist,<br>wird das Spiel auf
      diesem Ger\xE4t automatisch beendet.<br>M\xF6chtest du fortfahren?"
    m_Metadata:
      m_Items: []
  - m_Id: 7345453642100736
    m_Localized: Anzeigenbelohnung
    m_Metadata:
      m_Items: []
  - m_Id: 8319995684401152
    m_Localized: "F\xE4higkeit"
    m_Metadata:
      m_Items: []
  - m_Id: 8319995684401153
    m_Localized: "Autom. \xC4ndern"
    m_Metadata:
      m_Items: []
  - m_Id: 8319995684401154
    m_Localized: "\xC4ndern"
    m_Metadata:
      m_Items: []
  - m_Id: 8319995684401155
    m_Localized: Im Gange ...
    m_Metadata:
      m_Items: []
  - m_Id: 8321232555290624
    m_Localized: "F\xE4higkeitsrate"
    m_Metadata:
      m_Items: []
  - m_Id: 8322469497483264
    m_Localized: "Du hast die F\xE4higkeit nicht."
    m_Metadata:
      m_Items: []
  - m_Id: 8338546877083648
    m_Localized: "\xC4ndert F\xE4higkeiten automatisch bis Legend\xE4r oder Myth."
    m_Metadata:
      m_Items: []
  - m_Id: 8338546877083649
    m_Localized: Anhalten
    m_Metadata:
      m_Items: []
  - m_Id: 8338546877083650
    m_Localized: "Eine oder mehrere F\xE4higkeiten haben einen hohen Grad.<br>M\xF6chtest
      du es \xE4ndern?"
    m_Metadata:
      m_Items: []
  - m_Id: 8678641958203392
    m_Localized: "Autom. \xC4ndern ist im Gange."
    m_Metadata:
      m_Items: []
  - m_Id: 8741042564968448
    m_Localized: Runeneffekt
    m_Metadata:
      m_Items: []
  - m_Id: 9400078222307328
    m_Localized: "Schalte die F\xE4higkeitsvoreinstellung mit Diamanten frei."
    m_Metadata:
      m_Items: []
  - m_Id: 9767318272684032
    m_Localized: "W\xF6che. Limit {0}/{1}"
    m_Metadata:
