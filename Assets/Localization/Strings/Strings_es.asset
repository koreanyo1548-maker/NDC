      m_Items: []
  - m_Id: 5530286503571456
    m_Localized: Hay una solicitud de compra en curso. <br>Agradecemos tu espera.
    m_Metadata:
      m_Items: []
  - m_Id: 5829620440838144
    m_Localized: "Tienes una sesi\xF3n activa en otro dispositivo. <br>Si est\xE1s
