  - m_Id: 4814172551196678
    m_Localized: Cuervo
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196679
    m_Localized: Milton
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196680
    m_Localized: Harvey
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196681
    m_Localized: Ana
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196682
    m_Localized: "\xA1Mi adorable Ana!"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196683
    m_Localized: "\xA1M\xE1s all\xE1 es el Appole del mundo del M\xE1s all\xE1!"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196684
    m_Localized: "\xA1Hola, Ana!"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196685
    m_Localized: "\xBFQu\xE9 es esta transmisi\xF3n?"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196686
    m_Localized: "\xBFC\xF3mo puedo donar?"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196687
    m_Localized: "\xA1Somos los Saemsung del mundo del M\xE1s all\xE1!"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196688
    m_Localized: "\xBFQu\xE9 almorzaremos?"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196689
    m_Localized: "\xA1Srta. Ana! \xA1Hermosa!"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196690
    m_Localized: "Hoy est\xE1s hermosa, Ana."
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196691
    m_Localized: "\xA1Ana es tan hermosa!"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196692
    m_Localized: "\xA1Ja, ja, ja, ja!"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196693
    m_Localized: "\xA1Purifiquen almas, chicos!"
    m_Metadata:
      m_Items: []
  - m_Id: 4814172551196694
    m_Localized: "\xA1Qu\xE9 bella luce Ana! \xBFEs real?"
    m_Metadata:
      m_Items: []
  - m_Id: 1027676647433
    m_Localized: "Guerra, hambruna, cambio clim\xE1tico\u2026<br>La muerte se expande
      en toda la tierra contaminada."
    m_Metadata:
      m_Items: []
  - m_Id: 1027676647434
    m_Localized: "A su tiempo, las almas que no pudieron entrar al mundo del M\xE1s
      all\xE1<br>comenzaron a pudrirse"
    m_Metadata:
      m_Items: []
  - m_Id: 1027676647435
    m_Localized: "Y las almas contaminadas<br>desataron el caos en el M\xE1s all\xE1
      con extrema violencia."
    m_Metadata:
      m_Items: []
  - m_Id: 1027676647436
    m_Localized: "Ana es la presidenta ejecutiva de Vida Futura, <br>una compa\xF1\xEDa
      que administra el mundo del M\xE1s all\xE1,"
    m_Metadata:
      m_Items: []
  - m_Id: 1027676647437
    m_Localized: "form\xF3 un equipo de purificaci\xF3n de almas<br>para purificar
      este M\xE1s all\xE1 que est\xE1 sumido en un caos."
    m_Metadata:
      m_Items: []
  - m_Id: 1027676647438
    m_Localized: "El segador pasante, Cuervo, de Vida Futura<br>se une al proyecto
      de purificaci\xF3n de almas al comienzo de la aventura."
    m_Metadata:
      m_Items: []
